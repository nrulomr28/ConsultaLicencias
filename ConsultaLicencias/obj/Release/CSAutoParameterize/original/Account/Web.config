<?xml version="1.0"?>
<configuration>
  <system.web>
    <authorization>      
      <deny users="?"/>
    </authorization>
  </system.web>


  <location path="Manage.aspx">
    <system.web>
      <authorization>
        <deny users="?"/>
      </authorization>
    </system.web>
  </location>

  <location path="AdministraRolesUsuarios.aspx">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow roles="Administrador del Sistema"/>
      </authorization>
    </system.web>
  </location>

  <location path="Register.aspx">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow roles="Administrador del Sistema"/>
      </authorization>
    </system.web>
  </location>

  <location path="RegistroUsuario.aspx">
    <system.web>
      <authorization>
        <deny users="?"/>
        <allow roles="Administrador del Sistema"/>
      </authorization>
    </system.web>
  </location>
</configuration>
